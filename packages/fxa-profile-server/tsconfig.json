{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "allowJs": true,
    "checkJs": false,
    "module": "commonjs",
    "target": "ES2021",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["jest", "mocha", "mozlog", "node"],
    "lib": ["ESNext"],
    "noImplicitAny": false
  },
  "include": ["bin/*", "lib/**/*", "scripts/**/*", "test/**/*"],
  "exclude": ["node_modules", "dist"]
}
