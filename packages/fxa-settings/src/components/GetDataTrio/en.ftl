# GetDataTrio component, part of Account Recovery Key flow

get-data-trio-title-firefox = { -brand-firefox }
get-data-trio-title-firefox-recovery-key = { -brand-firefox } account recovery key
get-data-trio-title-backup-verification-codes = Backup authentication codes

# Since the buttons are of fixed width, Long label texts will be truncated.
# So, please keep translations of the labels short; a label should be no longer
# than the English word "Downloading" to fit in the button without truncation.
# If a full translation is too long, consider an accepted abbreviation that
# would fit in your locale, if such abbreviation exists.
# There is no length limit on the tooltip texts (the .title attribute). Use
# full translations there.
get-data-trio-download-v3 = <icon></icon><label>Download</label>
  .title = Download
get-data-trio-copy-v3 = <icon></icon><label>Copy</label>
  .title = Copy
get-data-trio-print-v3 = <icon></icon><label>Print</label>
  .title = Print

get-data-trio-copy-inline =
  .title = Copy
  .aria-label = Copy
