{
  "name": "fxa-profile-server",
  "version": "0.0.0",
  "private": true,
  "description": "Firefox Accounts Profile service.",
  "scripts": {
    "lint": "eslint .",
    "audit": "npm audit --json | audit-filter --nsp-config=.nsprc --audit=-",
    "clean": "rimraf dist",
    "outdated": "npm outdated --depth 0 || exit 0",
    "build": "echo 'Build not required'",
    "start": "pm2 start pm2.config.js",
    "stop": "pm2 stop pm2.config.js",
    "restart": "pm2 restart pm2.config.js",
    "delete": "pm2 delete pm2.config.js",
    "test": "yarn test-unit && yarn test-integration",
    "test-unit": "JEST_JUNIT_OUTPUT_FILE=../../artifacts/tests/$npm_package_name/fxa-profile-server-jest-unit-results.xml NODE_ENV=test npx jest --coverage --forceExit --testPathPattern='spec\\.ts$' --testPathIgnorePatterns='in\\.spec\\.ts$' --reporters=default --reporters=jest-junit",
    "test-integration": "JEST_JUNIT_OUTPUT_FILE=../../artifacts/tests/$npm_package_name/fxa-profile-server-jest-integration-results.xml NODE_ENV=test npx jest --coverage --forceExit --runInBand --testPathPattern='in\\.spec\\.ts$' --reporters=default --reporters=jest-junit",
    "format": "prettier --write --config ../../_dev/.prettierrc '**'"
  },
  "dependencies": {
    "@hapi/boom": "~10.0.0",
    "@hapi/catbox-memory": "~5.0.1",
    "@hapi/catbox-redis": "~6.0.2",
    "@hapi/hapi": "^20.2.1",
    "@hapi/inert": "7.1.1",
    "bluebird": "^3.7.2",
    "checksum": "1.0.0",
    "compute-cluster": "0.0.9",
    "convict": "^6.2.5",
    "convict-format-with-moment": "^6.2.0",
    "convict-format-with-validator": "^6.2.0",
    "fxa-shared": "workspace:*",
    "joi": "^17.13.3",
    "mozlog": "^3.0.2",
    "mysql": "^2.18.1",
    "poolee": "^1.0.1",
    "request": "^2.88.2",
    "sharp": "^0.35.0",
    "stream-to-array": "2.3.0"
  },
  "devDependencies": {
    "@types/sharp": "^0",
    "@types/sinon": "^17.0.0",
    "audit-filter": "^0.5.0",
    "commander": "9.3.0",
    "eslint": "^8.18.0",
    "jest-junit": "^16.0.0",
    "nock": "^13.5.1",
    "pm2": "^7.0.0",
    "pngparse": "2.0.1",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "sinon": "^14.0.0",
    "through": "2.3.8",
    "ts-jest": "^29.1.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mozilla/fxa.git"
  },
  "bugs": "https://github.com/mozilla/fxa/issues",
  "homepage": "https://github.com/mozilla/fxa/tree/main/packages/fxa-profile-server",
  "author": "Sean McArthur <sean.monstar@gmail.com>",
  "license": "MPL-2.0",
  "nx": {
    "tags": [
      "scope:server",
      "type:core"
    ]
  }
}
