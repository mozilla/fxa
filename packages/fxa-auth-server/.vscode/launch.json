{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Jest Current File",
      "program": "${workspaceFolder}/node_modules/.bin/jest",
      "args": ["--no-coverage", "--forceExit", "${relativeFile}"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "env": {
        "NODE_ENV": "dev",
        "VERIFIER_VERSION": "0",
        "CORS_ORIGIN": "http://foo,http://bar"
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Jest Unit Tests",
      "program": "${workspaceFolder}/node_modules/.bin/jest",
      "args": ["--no-coverage", "--selectProjects", "unit"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "env": {
        "NODE_ENV": "dev",
        "VERIFIER_VERSION": "0",
        "CORS_ORIGIN": "http://foo,http://bar"
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Jest Integration Tests",
      "program": "${workspaceFolder}/node_modules/.bin/jest",
      "args": [
        "--no-coverage",
        "--forceExit",
        "--selectProjects",
        "integration"
      ],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "env": {
        "NODE_ENV": "dev",
        "VERIFIER_VERSION": "0",
        "CORS_ORIGIN": "http://foo,http://bar"
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Verification Reminders",
      "args": [
        "-r",
        "ts-node/register/transpile-only",
        "-r",
        "tsconfig-paths/register",
        "${workspaceFolder}/scripts/verification-reminders.js"
      ],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "env": {
        "NODE_ENV": "dev"
      }
    }
  ]
}
