{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "allowJs": true,
    "checkJs": false,
    "module": "commonjs",
    "target": "ES2021",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["jest", "node"]
  },
  "include": ["lib/**/*", "test/**/*"],
  "exclude": ["node_modules", "dist"]
}
