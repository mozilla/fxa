## postChangeTwoStepAuthentication - This email is sent after user updates their
## two-step authentication connection.

postChangeTwoStepAuthentication-preview = Your account is protected
postChangeTwoStepAuthentication-subject = Two-step authentication updated
postChangeTwoStepAuthentication-title = Two-step authentication has been updated
# "new account" and "older entry" refer to the newly created Mozilla account
# entry in the authenticator app and the existing Mozilla account entry in the
# authenticator app, respectively.
postChangeTwoStepAuthentication-use-new-account = You now need to use the new account in your authenticator app. The older entry will no longer work and you can remove it.
# After the colon, there is a description of the device that the user used to update two-step authentication
postChangeTwoStepAuthentication-from-device = You requested this from:
postChangeTwoStepAuthentication-action = Manage account
postChangeTwoStepAuthentication-how-protects-link = How this protects your account
postChangeTwoStepAuthentication-how-protects-plaintext = How this protects your account:

##
