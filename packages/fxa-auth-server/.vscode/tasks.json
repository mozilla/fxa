{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Jest Current File",
      "type": "shell",
      "command": "npx jest --no-coverage --forceExit ${relativeFile}",
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated"
      },
      "options": {
        "env": {
          "NODE_ENV": "dev",
          "VERIFIER_VERSION": "0",
          "CORS_ORIGIN": "http://foo,http://bar"
        }
      }
    },
    {
      "label": "Stop PM2 Auth Server",
      "type": "shell",
      "command": "pm2 stop auth inbox profile"
    },
    {
      "label": "Start PM2 Auth Server",
      "type": "shell",
      "command": "pm2 start auth inbox profile"
    }
  ]
}
